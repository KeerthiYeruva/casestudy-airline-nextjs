rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Demo rules for the Next.js API-route architecture.
    // The app's route handlers use the Firebase Web SDK, so requests do not
    // include Firebase Auth user context. Use Firebase Admin SDK or forwarded
    // ID tokens before tightening these rules for production.
    function isKnownAppCollection(collectionName) {
      return collectionName in [
        'flights',
        'passengers',
        'shopItems',
        'ancillaryServices',
        'mealOptions',
        'shopCategories'
      ];
    }

    match /{collectionName}/{docId} {
      allow read, write: if isKnownAppCollection(collectionName);
    }

    // Deny access to anything not explicitly matched above.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
